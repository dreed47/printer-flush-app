# ── Printer ────────────────────────────────────────────────────────────────────
PRINTER_IP=192.168.86.99
PRINTER_PORT=631
PRINTER_PATH=/ipp/print

# ── Flush PDF ──────────────────────────────────────────────────────────────────
# Path inside the container (./data/ is mounted at /data)
FLUSH_PDF=/data/printer-color-flush.pdf

# ── Schedule ───────────────────────────────────────────────────────────────────
RUN_INTERVAL_DAYS=10          # Set to 0 for manual-only via web UI

# ── Web UI ─────────────────────────────────────────────────────────────────────
PORT=7841                     # External port for the web UI
TAGLINE=Keeping your nozzles wet since the dawn of inkjet.
TZ=America/Chicago            # Container timezone (e.g. America/New_York, America/Los_Angeles)
